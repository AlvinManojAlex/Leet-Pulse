{
  "manifest_version": 3,
  "name": "Leet-Pulse",
  "version": "0.1.0",
  "description": "Quietly tracks LeetCode activity for a custom watchlist of usernames.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://leetcode.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}
